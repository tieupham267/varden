# === Data source: how sidecar reads articles from Oksskolten ===
# Mode: 'sqlite' (recommended) or 'api'
OKSSKOLTEN_MODE=sqlite

# SQLite mode: path to Oksskolten's database (mounted read-only)
OKSSKOLTEN_DB_PATH=/oksskolten-data/oksskolten.db

# API mode: Oksskolten base URL (if you prefer REST API instead)
# OKSSKOLTEN_API_URL=http://oksskolten:3000
# OKSSKOLTEN_API_KEY=your-api-key

# === AI Provider ===
# Choose ONE provider. Supported values:
#   anthropic, gemini, azure-openai,
#   openai, deepseek, mistral, groq, together, fireworks, xai,
#   openrouter, ollama, openai-compatible
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Google Gemini ──
# GEMINI_API_KEY=AIzaSy-xxx
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Azure OpenAI ──
# AZURE_OPENAI_API_KEY=xxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── OpenAI ──
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── DeepSeek ──
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Mistral AI ──
# MISTRAL_API_KEY=xxx
# MISTRAL_MODEL=mistral-large-latest
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── Groq (fast inference) ──
# GROQ_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Together AI ──
# TOGETHER_API_KEY=xxx
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# ── Fireworks AI ──
# FIREWORKS_API_KEY=xxx
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── xAI (Grok) ──
# XAI_API_KEY=xai-xxx
# XAI_MODEL=grok-3-mini
# XAI_BASE_URL=https://api.x.ai/v1

# ── OpenRouter (multi-model gateway) ──
# OPENROUTER_API_KEY=sk-or-v1-xxx
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (local, self-hosted) ──
# OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=llama3.3
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Generic OpenAI-compatible (any provider with /chat/completions) ──
# Use AI_PROVIDER=openai-compatible, then set:
# OPENAI_API_KEY=xxx
# OPENAI_MODEL=model-name
# OPENAI_BASE_URL=https://your-provider.com/v1

# === Alert thresholds ===
# Relevance score (0-10) above which to send immediate alerts
ALERT_THRESHOLD=7
# Severity levels that trigger alerts: critical,high,medium
ALERT_SEVERITIES=critical,high

# === Scheduler ===
# How often to check for new articles (minutes)
POLL_INTERVAL_MINUTES=15
# Max articles to analyze per cycle (cost control)
BATCH_SIZE=20

# === Notification Channels ===
# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Slack
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK

# Email digest
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=security-team@company.com

# === State ===
STATE_DB_PATH=data/varden_state.db
LOG_FILE_PATH=data/varden.log
